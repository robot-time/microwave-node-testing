# Port this agent listens on (must match the public URL you register).
PORT=3847

# Local Ollama API (no trailing path)
OLLAMA_URL=http://127.0.0.1:11434

# Optional: must match NODE_DEVICE_TOKEN on the main Microwave server
NODE_DEVICE_TOKEN=

# Generation cap (passed to Ollama num_predict)
OLLAMA_NUM_PREDICT=1024

# keep_alive for Ollama (e.g. 30m, -1)
OLLAMA_KEEP_ALIVE=30m
